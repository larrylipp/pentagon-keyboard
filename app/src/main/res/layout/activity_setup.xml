<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0E0C0A">

    <ImageView
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:src="@drawable/ic_launcher"
        android:layout_marginBottom="12dp"
        android:contentDescription="Pentagon Keyboard"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_title"
        android:textSize="20sp"
        android:textColor="#E8DFC8"
        android:textStyle="bold"
        android:layout_marginBottom="28dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/setup_step1"
        android:textSize="14sp"
        android:textColor="#8A7F68"
        android:gravity="center"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_enable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_enable"
        android:backgroundTint="#C9A84C"
        android:textColor="#0E0C0A"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/setup_step2"
        android:textSize="14sp"
        android:textColor="#8A7F68"
        android:gravity="center"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_select"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_select"
        android:backgroundTint="#C9A84C"
        android:textColor="#0E0C0A"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_settings"
        android:backgroundTint="#2A1A08"
        android:textColor="#C9A84C"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_done"
        android:textSize="14sp"
        android:textColor="#6ADDB0"
        android:visibility="gone"/>

</LinearLayout>
