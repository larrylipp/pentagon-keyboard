<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0806">

    <!-- Suggestion bar -->
    <LinearLayout
        android:id="@+id/suggestion_bar"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical"
        android:background="#110E08">

        <TextView android:id="@+id/suggestion_0"
            android:layout_width="0dp" android:layout_height="26dp"
            android:layout_weight="1" android:gravity="center"
            android:textSize="13sp" android:textColor="#C9A84C"
            android:background="@drawable/suggestion_bg"
            android:layout_marginEnd="3dp" android:visibility="invisible"/>

        <TextView android:id="@+id/suggestion_1"
            android:layout_width="0dp" android:layout_height="26dp"
            android:layout_weight="1" android:gravity="center"
            android:textSize="13sp" android:textColor="#8A7F68"
            android:background="@drawable/suggestion_bg"
            android:layout_marginEnd="3dp" android:visibility="invisible"/>

        <TextView android:id="@+id/suggestion_2"
            android:layout_width="0dp" android:layout_height="26dp"
            android:layout_weight="1" android:gravity="center"
            android:textSize="13sp" android:textColor="#8A7F68"
            android:background="@drawable/suggestion_bg"
            android:visibility="invisible"/>
    </LinearLayout>

    <!-- Main row: pentagon + side panel (order swapped for right-hand mode in Java) -->
    <LinearLayout
        android:id="@+id/main_row"
        android:layout_width="match_parent"
        android:layout_height="225dp"
        android:orientation="horizontal">

        <!-- Pentagon view (left by default, moved right for right-hand mode) -->
        <com.pentagonkeyboard.PentagonKeyboardView
            android:id="@+id/keyboard_view"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"/>

        <!-- Side panel (right by default, moved left for right-hand mode) -->
        <com.pentagonkeyboard.SidePanel
            android:id="@+id/side_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"/>

    </LinearLayout>

    <!-- Space bar -->
    <TextView
        android:id="@+id/space_bar"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:gravity="center"
        android:text="SPACE"
        android:textSize="11sp"
        android:letterSpacing="0.3"
        android:textColor="#8A7F68"
        android:background="#1A1208"/>

</LinearLayout>
